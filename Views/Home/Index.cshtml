@model EmailSignatureApp.Models.SignatureViewModel

@{
    ViewData["Title"] = "Sua Assinatura";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card shadow-sm mb-4">
            <div class="card-header" style="background-color: #1F4E79; color: white;">
                <h5 class="mb-0">👤 Seus Dados</h5>
            </div>
            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        ⚠️ @ViewBag.Error
                    </div>
                }

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-muted small">NOME COMPLETO</label>
                        <div class="form-control bg-light">@Model.DisplayName</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-muted small">CARGO</label>
                        <div class="form-control bg-light">@Model.Description</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-muted small">SETOR / LOTAÇÃO</label>
                        <div class="form-control bg-light">@Model.Office</div>
                    </div>
                </div>

            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SignatureHtml))
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header" style="background-color: #2E75B6; color: white;">
                    <h5 class="mb-0">Preview da Assinatura</h5>
                </div>
                <div class="card-body bg-white p-4">
                    <div id="signature-preview">
                        @Html.Raw(Model.SignatureHtml)
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Utilize sua Assinatura</h5>
                </div>
                <div class="card-body">

                    <div id="copy-feedback" class="alert alert-success d-none mb-3">
                        ✅ Assinatura copiada! Agora abra o Outlook e cole com <strong>Ctrl+V</strong>.
                    </div>

                    <button id="btn-copy" class="btn btn-lg w-100"
                            style="background-color: #1F4E79; color: white;">
                        📋 Copiar
                    </button>

                    <div class="mt-4 p-3 bg-light rounded border">
                        <p class="fw-bold mb-2">📌 Como usar no Outlook:</p>
                        <ol class="mb-0 small text-muted">
                            <li>Clique em <strong>Copiar Assinatura</strong> acima</li>
                            <li>No Outlook, acesse <strong>Arquivo → Opções → Email → Assinaturas</strong></li>
                            <li>Crie uma nova assinatura ou edite uma existente</li>
                            <li>Clique na área de texto da assinatura e cole com <strong>Ctrl+V</strong></li>
                            <li>Clique em <strong>OK</strong> para salvar</li>
                        </ol>
                    </div>

                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btn-copy')?.addEventListener('click', async () => {
            const preview = document.getElementById('signature-preview');

            try {
                // Tenta Clipboard API moderna (Chrome, Edge modernos)
                await navigator.clipboard.write([
                    new ClipboardItem({
                        'text/html': new Blob([preview.innerHTML], { type: 'text/html' }),
                        'text/plain': new Blob([preview.innerText], { type: 'text/plain' })
                    })
                ]);
            } catch {
                // Fallback: seleciona o elemento HTML renderizado e copia
                const range = document.createRange();
                range.selectNode(preview);
                const selection = window.getSelection();
                selection.removeAllRanges();
                selection.addRange(range);
                document.execCommand('copy');
                selection.removeAllRanges();
            }

            showFeedback();
        });

        function showFeedback() {
            const feedback = document.getElementById('copy-feedback');
            feedback.classList.remove('d-none');
            setTimeout(() => feedback.classList.add('d-none'), 5000);
        }
    </script>
}